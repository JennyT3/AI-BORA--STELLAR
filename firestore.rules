rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /solicitudes/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /contactos/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /propostas/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resposta', 'dataResposta']) && request.resource.data.resposta != null);
    }

    match /clientes/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['categoria', 'processo', 'resposta', 'dataResposta']) && request.resource.data.categoria != null);
    }

    match /vendedores/{id} {
      allow read, write: if request.auth != null;
    }

    match /faturas/{id} {
      allow read, write: if request.auth != null;
    }

    match /tareas/{id} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
