rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Verificar se está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verificar se é admin (role no documento do vendedor)
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/vendedores/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/vendedores/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Verificar se é o próprio vendedor
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Verificar se o vendedor tem acesso ao cliente
    function canAccessCliente() {
      return isAdmin() || 
        (isAuthenticated() && resource.data.vendedorId == request.auth.uid);
    }

    // ============================================
    // ACADEMIA BORA LÁ
    // ============================================
    
    // Usuarios Academia: solo su propio documento
    match /academia_users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Progresso: solo el usuario dono
    match /academia_progresso/{docId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow write: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
    }
    
    // Certificados: lectura pública para verificación, escritura solo dueño
    match /academia_certificados/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
    }
    
    // Quizzes: lectura pública (preguntas), escritura admin
    match /academia_quizzes/{quizId} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================
    // SOLICITUDES (público - qualquer pessoa pode criar)
    // ============================================
    match /solicitudes/{id} {
      allow create: if request.resource.data.keys().hasAll(['nome', 'telefone']);
      allow read: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ============================================
    // CLIENTES (protegido)
    // ============================================
    match /clientes/{id} {
      // Qualquer um logado pode ler (para listas)
      allow read: if isAuthenticated();
      // Só admins podem criar
      allow create: if isAdmin();
      // Só admins ou o vendedor asignado podem editar
      allow update: if isAdmin() || 
        (isAuthenticated() && resource.data.vendedorId == request.auth.uid);
      // Só admins podem eliminar
      allow delete: if isAdmin();
    }

    // ============================================
    // PROPOSTAS (protegido)
    // ============================================
    match /propostas/{id} {
      // Authenticated users can read
      allow read: if isAuthenticated();
      // Only admins can create
      allow create: if isAdmin();
      // Only owner can update specific fields (resposta)
      allow update: if isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resposta', 'dataResposta', 'respondidoPor']);
      // Only admins can delete
      allow delete: if isAdmin();
    }

    // ============================================
    // VENDEDORES (muito sensível)
    // ============================================
    match /vendedores/{id} {
      // Só o próprio vendedor pode ler os seus dados
      allow read: if isAuthenticated() && request.auth.uid == id;
      // Só admins podem criar/editar
      allow write: if isAdmin();
    }

    // ============================================
    // TAREFAS (protegido)
    // ============================================
    match /tareas/{id} {
      // Authenticated can read
      allow read: if isAuthenticated();
      // Only admins can create
      allow create: if isAdmin();
      // Admin or assigned vendor can update
      allow update: if isAdmin() || 
        (isAuthenticated() && resource.data.asignadaA == request.auth.uid);
      // Only admins can delete
      allow delete: if isAdmin();
    }

    // ============================================
    // FATURAS (muito sensível - só admin)
    // ============================================
    match /faturas/{id} {
      allow read, write, delete: if isAdmin();
    }
    
    match /faturas_recorrentes/{id} {
      allow read, write, delete: if isAdmin();
    }

    // ============================================
    // CONTACTOS (público criar, protegido ler)
    // ============================================
    match /contactos/{id} {
      // Qualquer pessoa pode criar (sem auth) para formulários públicos
      allow create: if request.resource.data.keys().hasAll(['nome', 'email']);
      // Só autenticados podem ler
      allow read: if isAuthenticated();
      // Só admins podem editar/eliminar
      allow update, delete: if isAdmin();
    }

    // ============================================
    // REGISTOS DE EMAIL (logs - só admin)
    // ============================================
    match /registos_email/{id} {
      allow read, write, delete: if isAdmin();
    }

    // ============================================
    // COMISSÕES (muito sensível - só admin)
    // ============================================
    match /comisiones/{id} {
      allow read, write, delete: if isAdmin();
    }

    // ============================================
    // DEFAULT DENY (segurança máxima)
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}