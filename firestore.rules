rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // PERMISOS ABIERTOS PARA HACKATHON
    // Todo el mundo puede leer y escribir en todo
    // ============================================
    match /{document=**} {
      allow read, write: if true;
    }
    
    // EXCEPCIONES: Solo lectura para seguridad
    match /vendedores/{id} {
      allow read: if true;
      allow write: if false;
    }
    
    match /comisiones/{id} {
      allow read: if true;
      allow write: if false;
    }
    
    match /faturas/{id} {
      allow read: if true;
      allow write: if false;
    }
    
    match /faturas_recorrentes/{id} {
      allow read: if true;
      allow write: if false;
    }
    
    match /registos_email/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}