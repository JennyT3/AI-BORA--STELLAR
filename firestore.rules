rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: es admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/vendedores/$(request.auth.uid))) &&
        get(/databases/$(database)/documents/vendedores/$(request.auth.uid)).data.role == 'admin';
    }

    // SOLICITUDES
    match /solicitudes/{id} {
      allow create: if request.resource.data.keys().hasAll(['nome', 'telefone', 'servicos']);
      allow read: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // CLIENTES
    match /clientes/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin() || 
        (request.auth != null && resource.data.vendedorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // PROPOSTAS
    match /propostas/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resposta', 'dataResposta'])
      );
      allow delete: if isAdmin();
    }

    // VENDEDORES
    match /vendedores/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // TAREFAS
    match /tareas/{id} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin() || 
        (request.auth != null && resource.data.asignadaA == request.auth.uid);
      allow delete: if isAdmin();
    }

    // FATURAS
    match /faturas/{id} {
      allow read, write, delete: if isAdmin();
    }

    // CONTACTOS
    match /contactos/{id} {
      allow create: if request.resource.data.keys().hasAll(['nome', 'email']);
      allow read, update, delete: if request.auth != null;
    }

    // DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
