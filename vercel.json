{
  "version": 2,
  "rewrites": [
    { "source": "/proposta", "destination": "/proposta.html" },
    { "source": "/baixar-pdf", "destination": "/baixar-pdf.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(mp4|webm|ogg|jpg|jpeg|png|svg|webp|gif|html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
