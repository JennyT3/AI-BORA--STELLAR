# ============================================
# CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE
# ============================================
# Copie este ficheiro para .env.local e preencha os valores reais
# NÃO COMMITAR .env.local - já está no .gitignore

# --- FIREBASE (público - estas keys são seguras) ---
VITE_FIREBASE_API_KEY=AIzaSyD_EXISTING_KEY
VITE_FIREBASE_AUTH_DOMAIN=aibora-propostas.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=aibora-propostas
VITE_FIREBASE_STORAGE_BUCKET=aibora-propostas.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# --- GOOGLE SCRIPT (endpoint do Google Apps Script) ---
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/SEU_SCRIPT_ID/exec

# --- FIREBASE CLOUD FUNCTIONS (URL para chamadas) ---
# Desenvolvimento: http://localhost:5001/aibora-propostas/us-central1/sendEmail
# Produção: https://us-central1-aibora-propostas.cloudfunctions.net/sendEmail
VITE_CLOUD_FUNCTION_URL=https://us-central1-aibora-propostas.cloudfunctions.net/sendEmail

# --- RESEND API KEY (configurado no Firebase Functions, não aqui) ---
# A API key do Resend deve estar configurada nas Firebase Cloud Functions
# Obtendo em: https://resend.com/settings/api-keys
# Configurar nas Cloud Functions com: firebase functions:secrets:set RESEND_API_KEY

# --- ADMIN (credenciais de acesso) ---
VITE_ADMIN_PASSWORD=your_admin_password_aqui