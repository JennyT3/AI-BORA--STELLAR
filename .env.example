# AI BORA - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================
# STELLAR BLOCKCHAIN CONFIGURATION
# ============================================
# Your Stellar testnet account (secret key)
# Get testnet funds at: https://friendbot.stellar.org
VENDOR_SECRET=YOUR_STELLAR_SECRET_KEY_HERE

# Public key (derived from secret)
VENDOR_PUBLIC=YOUR_STELLAR_PUBLIC_KEY_HERE

# Client account for demo
CLIENT_SECRET=YOUR_CLIENT_SECRET_KEY_HERE
CLIENT_PUBLIC=YOUR_CLIENT_PUBLIC_KEY_HERE

# ============================================
# FIREBASE CONFIGURATION
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ============================================
# CLERK AUTHENTICATION
# ============================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key

# ============================================
# APP CONFIGURATION
# ============================================
VITE_APP_URL=http://localhost:3000